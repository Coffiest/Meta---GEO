// GEO(仮称)戦略DBの基礎スキーマ。
// 「全ハンド・全アクションを記録し、後からスポットごとに検索・分析できる」というコンセプトの核。
// ローカル開発ではこの環境のPostgres、本番ではSupabase Postgresを想定(DATABASE_URLを切り替えるだけ)。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  /// Supabase Authのユーザーid(auth.users.id)。BOTユーザーはnull。
  authId      String?  @unique
  email       String?  @unique
  displayName String
  /// プリセットアバターのキー(apps/web側の定義と対応)。未選択はnull。
  avatarKey   String?
  /// 初回オンボーディング(名前+アバター設定)を完了したか。未完了ユーザーはホームに入れない。
  onboarded   Boolean  @default(false)
  isBot       Boolean  @default(false)
  createdAt   DateTime @default(now())

  tournamentEntries    TournamentEntry[]
  handSeats            HandSeat[]
  bankrollTransactions BankrollTransaction[]
  subscription         Subscription?
}

/// GEO戦略DB(レンジ分析)の月額サブスクリプション状態。Stripeのsubscriptionオブジェクトと
/// stripeSubscriptionId/stripeCustomerIdで対応させ、Webhookでstatusを同期する。
model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  /// "active" | "trialing" | "past_due" | "canceled" | "incomplete"
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
}

/// 無料プランの1日あたりGEO閲覧回数トラッキング。日付が変わったら新しい行として扱う(リセット不要)。
model GeoViewUsage {
  id        String   @id @default(uuid())
  userId    String
  /// "YYYY-MM-DD"形式(UTC基準)。
  date      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

/// 棋譜解析(トーナメント単位)の無料枠トラッキング。無料プランは24時間ローリングで1回まで。
/// (userId, tournamentId)で一意=同一トナメの再解析は消費しない(冪等)。直近24時間の行数で判定する。
model ReviewUsage {
  id           String   @id @default(uuid())
  userId       String
  tournamentId String
  createdAt    DateTime @default(now())

  @@unique([userId, tournamentId])
  @@index([userId, createdAt])
}

/// プレイヤーメモ&マーキング。あるユーザー(author)が対戦相手(target)につける
/// 色分類(赤/橙/黄/青/紫)+自由記述メモ。GTO WizardやTenFourのHUD的な「相手ノート」機能。
/// author×targetで一意(1相手につき1メモ)。
model PlayerNote {
  id           String   @id @default(uuid())
  /// メモを付けた本人のUser.id
  authorUserId String
  /// メモの対象プレイヤーのUser.id
  targetUserId String
  /// 色分類。"red"|"orange"|"yellow"|"blue"|"purple" のいずれか、未設定はnull。
  color        String?
  /// 自由記述メモ本文。
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([authorUserId, targetUserId])
  @@index([authorUserId])
  @@index([targetUserId])
}

/// バンクロール(バーチャルチップの持ち点)の増減台帳。残高はこの台帳のamount合計で常に導出する
/// (別に「現在残高」フィールドをキャッシュしない。導出元は常にこの台帳の1本にする)。
model BankrollTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  /// 正=入金(サインアップボーナス・賞金)、負=出金(バイイン)
  amount       Int
  kind         String // "signupBonus" | "buyIn" | "payout" | "adjustment"
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Tournament {
  id            String    @id @default(uuid())
  /// "sng" | "mtt"。ロビーでの選択に対応。
  gameType      String    @default("sng")
  /// 参加費(バンクロールから引かれる額)。トーナメント内のチップ数(startingStack)とは別概念。
  buyIn         Int       @default(0)
  seatCount     Int
  startingStack Int
  status        String    @default("waiting") // "waiting" | "running" | "finished"
  createdAt     DateTime  @default(now())
  finishedAt    DateTime?

  entries              TournamentEntry[]
  hands                Hand[]
  bankrollTransactions BankrollTransaction[]
}

model TournamentEntry {
  id                 String  @id @default(uuid())
  tournamentId       String
  tournament         Tournament @relation(fields: [tournamentId], references: [id])
  userId             String
  user               User    @relation(fields: [userId], references: [id])
  seatIndex          Int
  finishPosition     Int?
  bustedAtHandNumber Int?
  /// 着順に応じてバンクロールへ払い出した額(0=賞金圏外)。
  payout             Int     @default(0)

  @@unique([tournamentId, seatIndex])
  @@index([userId])
}

model Hand {
  id              String   @id @default(uuid())
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  handNumber      Int
  levelSmallBlind Int
  levelBigBlind   Int
  levelAnte       Int
  buttonFixedPos  Int
  board           String[] // 例: ["9s","8s","7s","6h","2d"]
  potTotal        Int
  wonByFold       Boolean
  createdAt       DateTime @default(now())

  seats   HandSeat[]
  actions HandAction[]
  pots    HandPot[]
  reviews HandReview[]

  @@unique([tournamentId, handNumber])
}

/// そのハンドにおける各プレイヤーの着席情報。GEO分析上、全ハンド終了後はホールカードを常に記録する
/// (Ten-Four Pokerの「全履歴公開」思想を踏襲)。
model HandSeat {
  id               String  @id @default(uuid())
  handId           String
  hand             Hand    @relation(fields: [handId], references: [id])
  userId           String
  user             User    @relation(fields: [userId], references: [id])
  seatIndex        Int
  startingStack    Int
  holeCards        String[]
  isSmallBlind     Boolean @default(false)
  isBigBlind       Boolean @default(false)
  resultStackDelta Int
  /// Historyタブでプレイヤーが「お気に入り」登録したハンドかどうか。
  isFavorite       Boolean @default(false)
  /// そのハンド中、このプレイヤーが離席状態(自動チェック/フォールド)だったか。
  /// 離席中の意思決定は本人の戦略ではないため、GEO戦略分析の集計から除外する。
  wasAway          Boolean @default(false)

  @@unique([handId, seatIndex])
  @@index([userId])
}

/// GEO分析の核となる、ハンド内の全アクションの時系列ログ
model HandAction {
  id             String @id @default(uuid())
  handId         String
  hand           Hand   @relation(fields: [handId], references: [id])
  sequenceNumber Int
  seatIndex      Int
  street         String // "preflop" | "flop" | "turn" | "river"
  kind           String // "fold" | "check" | "call" | "bet" | "raise" | "allIn" | "postBlind" | "postAnte"
  toAmount       Int?
  potBefore      Int

  @@index([handId, sequenceNumber])
  @@index([street, kind])
}

model HandPot {
  id              String @id @default(uuid())
  handId          String
  hand            Hand   @relation(fields: [handId], references: [id])
  potIndex        Int
  amount          Int
  eligibleUserIds String[]
  winnerUserIds   String[]

  @@unique([handId, potIndex])
}

/// 局後検討(GTO棋譜解析)の「正解データ」= 自社ソルバーで計算したGTO解のプリコンピュート/キャッシュ。
/// 他社サービスのスクレイピングではなく、あくまで自前で計算した自社データを格納する。
/// spotKeyは局面を正規化した一意キー(street/有効スタック帯/相対ポジション/スート正規化ボード/
/// アクションライン/ベットサイズ抽象化 を連結してハッシュ化)。詳細は packages/db/src/solverSpot.ts。
model GtoSolution {
  id             String   @id @default(uuid())
  /// 局面を正規化した一意キー(sha1)。キャッシュ命中判定に使う。
  spotKey        String   @unique
  street         String // "preflop" | "flop" | "turn" | "river"
  /// 有効スタック帯(stackBucketと同じ区分)。
  effStackBucket String
  /// 相対ポジション。ポストフロップHUは "IP" | "OOP"。プリフロップは "BTN" 等の絶対ポジション。
  heroPos        String
  /// スート正規化済みボード(例: "AaKb7c")。プリフロップは空文字。
  boardCanon     String
  /// そのストリート内で直面したアクションライン(バケット列)を連結した文字列。
  actionLine     String
  /// ベットサイズ抽象化のID(どのサイズ木で解いたか)。
  betTree        String
  /// per-actionの頻度とEVを格納したペイロード。{ actions: [{ action, freq, evBb }], ... }
  solution       Json
  /// 収束品質(exploitability, %pot等)。プリフロップの表引きは0扱い。
  exploitability Float    @default(0)
  /// 解の生成元バージョン(ソルバー版 or レンジ表版)。
  solverVersion  String   @default("preflop-table-v1")
  createdAt      DateTime @default(now())

  @@index([street, effStackBucket])
}

/// 1ハンドに対する1プレイヤー(hero)ぶんのレビュージョブ+集計結果。
model HandReview {
  id           String   @id @default(uuid())
  handId       String
  hand         Hand     @relation(fields: [handId], references: [id])
  /// レビュー対象(意思決定を分析する)プレイヤーのUser.id。
  heroUserId   String
  /// "queued" | "solving" | "explaining" | "done" | "failed"
  status       String   @default("queued")
  error        String?
  /// トナメ/ハンド単位のGTO精度%(0-100)。チェスドットコムのAccuracy相当。
  gtoAccuracy  Float?
  totalEvLossBb Float?
  mistakeCount  Int?
  artisticCount Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  decisions ReviewDecision[]

  @@unique([handId, heroUserId])
  @@index([status])
}

/// heroの1意思決定ぶんの分析結果。
model ReviewDecision {
  id               String  @id @default(uuid())
  reviewId         String
  review           HandReview @relation(fields: [reviewId], references: [id])
  /// 対応するHandAction.sequenceNumber。
  sequenceNumber   Int
  street           String
  /// 解析対象か。多人数ポストフロップ等はfalse。
  analyzable       Boolean @default(true)
  /// 対象外の理由。"multiway" 等。
  outOfScopeReason String?
  heroPos          String
  effStackBb       Float
  potBb            Float
  facingSizeBb     Float?
  /// { action, size, bucket } 実際に取ったアクション。
  actionTaken      Json
  /// [{ action, size, freq, evBb }] GTO基準の各アクション。
  gtoActions       Json?
  evLossBb         Float?
  /// "artistic" | "best" | "great" | "excellent" | "good" | "book" | "inaccuracy" | "mistake" | "blunder" | null
  classification   String?
  /// 呼称ラベル(例 "チェックレイズ")。チャットボット未実装時の「正解表示」用。
  actionName       String?
  /// 将来のチャットボット解説文(フェーズ3)。未実装時はnull。
  explanation      String?
  spotKey          String?

  @@index([reviewId])
}
